{
  "name": "@flexiui/svelte-color-picker",
  "version": "0.0.1",
  "description": "A lightweight and flexible color picker component for Svelte",
  "keywords": [
    "svelte",
    "color-picker",
    "component"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && svelte-package",
    "preview": "vite preview"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "sideEffects": [
